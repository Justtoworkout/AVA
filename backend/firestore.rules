rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── calls collection ───────────────────────────────────────────────────
    // Allows public read access for the supervisor dashboard app (which does not implement Firebase Auth).
    // Restricts writes strictly to the authenticated Firebase Admin SDK (Vapi webhook).
    match /calls/{callId} {
      allow read: if true;
      allow write: if false; // Admin SDK only
    }

    // ── Deny everything else by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
