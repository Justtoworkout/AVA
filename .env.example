# ==============================================================
# AVA — Environment Variables
# Copy to .env and fill in real values (never commit .env)
# ==============================================================

# Firebase
FIREBASE_PROJECT_ID=gamma-86108
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Google Calendar API (service account JSON or OAuth2)
GOOGLE_CALENDAR_ID=c.v.kewin@gmail.com
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Vapi webhook secret (for Cloud Function signature verification)
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# Optional: Cloud Function URL (set after deploy)
CLOUD_FUNCTION_WEBHOOK_URL=https://us-central1-gamma-86108.cloudfunctions.net/vapiWebhook
